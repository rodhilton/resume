<% load 'lib/common.rb' %>
<h2 id="projects-heading" class="mb-5">Projects</h2>
<p>Various public projects I work on from time to time.</p>
<br/>
<% projs = projects.sort_by {|a| a.time }.reverse %>
<% projs.each do |proj| %>
<div class="resume-item d-flex flex-column flex-md-row mb-5">
    <div class="resume-content mr-auto">
        <h3 class="mb-0"><a href="<%= proj.url %>"><%= proj.title %></a></h3>
        <div class="subheading mb-3"><%= proj.role %></div>
        <p><%= proj.description %></p>
    </div>
    <% unless proj.icon.nil? %>
    <div class="resume-date text-md-right">
        <p><img class="icon" src="img/<%= proj.icon %>" alt="" aria-hidden="true"/></p>
    </div>
    <% end %>
</div>
<% end %>
